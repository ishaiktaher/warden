CONTROL_PLANE_ENV=dev
CONTROL_PLANE_ADMIN_KEY=replace_with_a_long_random_admin_key
CONTROL_PLANE_DATABASE=./data/control_plane.db
CONTROL_PLANE_DATA_DIR=./data
CONTROL_PLANE_ISSUER=warden-control-plane
CONTROL_PLANE_AUDIENCE=warden-action-gateway
CONTROL_PLANE_SECRETS_KEY=
CONTROL_PLANE_ALLOWED_EGRESS_HOSTS=
WARDEN_ALLOWED_ORIGINS=http://127.0.0.1:3000
WARDEN_PUBLIC_URL=http://127.0.0.1:8000
WARDEN_AUTO_MIGRATE=false
WARDEN_MAX_REQUEST_BYTES=1048576

# Production portable infrastructure (required when CONTROL_PLANE_ENV=prod)
DATABASE_URL=postgresql://warden:replace_me@db.internal:5432/warden?sslmode=require
REDIS_URL=rediss://cache.internal:6379/0
WARDEN_OIDC_ISSUER=https://your-identity-provider.example.com/
WARDEN_OIDC_AUDIENCE=https://api.warden.example.com
WARDEN_OIDC_TENANT_CLAIM=tenant_id
WARDEN_OIDC_ROLES_CLAIM=roles
WARDEN_OIDC_ON_BEHALF_OF_CLAIM=on_behalf_of
WARDEN_OIDC_JWKS_CACHE_SECONDS=300
OTEL_EXPORTER_OTLP_ENDPOINT=

# Built-ins: http; aws_*; azure_*; gcp_*; vault_*; pkcs11; or module.path:factory.
# "local" is development-only and is rejected in production.
WARDEN_SIGNING_PROVIDER=http
WARDEN_SECRETS_PROVIDER=http
WARDEN_AUDIT_PROVIDER=http
WARDEN_SIGNING_PROVIDER_URL=https://security-provider.example.com
WARDEN_SECRETS_PROVIDER_URL=https://security-provider.example.com
WARDEN_AUDIT_PROVIDER_URL=https://security-provider.example.com
WARDEN_PROVIDER_AUTH_TOKEN=replace_with_provider_workload_token
WARDEN_SIGNING_KEY_ID=
WARDEN_SECRETS_PREFIX=
WARDEN_AUDIT_TARGET=
WARDEN_PROVIDER_REGION=
WARDEN_PROVIDER_MOUNT=
WARDEN_PROVIDER_NAMESPACE=
WARDEN_PROVIDER_LIBRARY=
WARDEN_PROVIDER_TOKEN_LABEL=

# Optional AWS adapter configuration (only when selecting aws_* providers)
# WARDEN_PROVIDER_REGION=ap-south-1
# WARDEN_SIGNING_KEY_ID=alias/warden-capability-signing
# WARDEN_SECRETS_PREFIX=/warden/prod/connectors
# WARDEN_AUDIT_TARGET=warden-production-audit

# See docs/PROVIDERS.md for Azure, Google Cloud, Vault, and PKCS#11 examples.
